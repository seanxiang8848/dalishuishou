# 大力水手 - 环境配置文件

# 服务器配置
PORT=3000
NODE_ENV=development

# MySQL数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=dalishuishou
DB_USER=root
DB_PASSWORD=your_mysql_password

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT密钥（生产环境请更换为强密码）
JWT_SECRET=dalishuishou_jwt_secret_2024_change_in_production
JWT_EXPIRES_IN=7d

# 文件上传配置
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# 高德地图API（需要申请）
GAODE_KEY=your_gaode_api_key

# 抖音开放平台（需要申请）
DOUYIN_APP_ID=your_douyin_app_id
DOUYIN_APP_SECRET=your_douyin_app_secret

# 极光推送（需要申请）
JPUSH_APP_KEY=your_jpush_app_key
JPUSH_MASTER_SECRET=your_jpush_master_secret
